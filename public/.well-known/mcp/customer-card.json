{
  "name": "Movepark Customer",
  "description": "MCP do Movepark (consumidor autenticado): descoberta, login por OTP (WhatsApp/e-mail) e reserva em nome do usuário final. O pagamento é feito num link de checkout. Endpoint: https://mcp.movepark.co/customer",
  "url": "https://mcp.movepark.co/customer",
  "transport": "streamable-http",
  "contact": "contato@movepark.co",
  "authentication": {
    "type": "user-otp",
    "note": "Login passwordless: request_login_otp dispara o código, verify_login_otp devolve a sessão. As tools de reserva recebem Authorization: Bearer <access_token>."
  },
  "tools": [
    {
      "name": "search_parking",
      "description": "Busca estacionamentos por destino e período, com preço, distância e disponibilidade.",
      "inputSchema": {
        "type": "object",
        "properties": {
          "dest": {
            "type": "string",
            "description": "Código do aeroporto (ex.: GRU) ou cidade"
          },
          "from": {
            "type": "string",
            "format": "date-time"
          },
          "to": {
            "type": "string",
            "format": "date-time"
          },
          "vehicle": {
            "type": "string",
            "enum": [
              "car",
              "motorcycle"
            ]
          },
          "category": {
            "type": "array",
            "items": {
              "type": "string"
            }
          },
          "max_distance_km": {
            "type": "number"
          },
          "limit": {
            "type": "integer"
          }
        },
        "required": [
          "dest",
          "from",
          "to"
        ]
      }
    },
    {
      "name": "simulate_price",
      "description": "Simula o preço de uma reserva por empresa/unidade/tipo de vaga e nº de diárias.",
      "inputSchema": {
        "type": "object",
        "properties": {
          "company": {
            "type": "string",
            "description": "slug da empresa"
          },
          "location": {
            "type": "string",
            "description": "slug da unidade"
          },
          "parking_type": {
            "type": "string",
            "description": "code do tipo de vaga"
          },
          "days": {
            "type": "integer",
            "minimum": 1,
            "default": 1
          }
        },
        "required": [
          "company"
        ]
      }
    },
    {
      "name": "get_faq",
      "description": "Perguntas frequentes globais ou de uma unidade específica.",
      "inputSchema": {
        "type": "object",
        "properties": {
          "location_id": {
            "type": "string"
          },
          "query": {
            "type": "string"
          },
          "limit": {
            "type": "integer"
          }
        }
      }
    },
    {
      "name": "list_companies",
      "description": "Lista os estacionamentos parceiros (empresas) da plataforma.",
      "inputSchema": {
        "type": "object",
        "properties": {
          "limit": {
            "type": "integer"
          }
        }
      }
    },
    {
      "name": "list_locations",
      "description": "Lista unidades (estacionamentos) públicas.",
      "inputSchema": {
        "type": "object",
        "properties": {
          "limit": {
            "type": "integer"
          }
        }
      }
    },
    {
      "name": "get_parking_types",
      "description": "Tipos de vaga de uma unidade (coberto, descoberto, valet).",
      "inputSchema": {
        "type": "object",
        "properties": {
          "location_id": {
            "type": "string"
          }
        },
        "required": [
          "location_id"
        ]
      }
    },
    {
      "name": "list_destinations",
      "description": "Destinos (aeroportos/cidades) atendidos, com slug e localização.",
      "inputSchema": {
        "type": "object",
        "properties": {
          "limit": {
            "type": "integer"
          }
        }
      }
    },
    {
      "name": "get_destination",
      "description": "Detalhe de um destino pelo slug, com seus pontos/terminais.",
      "inputSchema": {
        "type": "object",
        "properties": {
          "slug": {
            "type": "string"
          }
        },
        "required": [
          "slug"
        ]
      }
    },
    {
      "name": "current_datetime",
      "description": "Data e hora atuais no fuso de São Paulo. Use para resolver datas relativas como 'amanhã' ou 'sexta que vem' sem perguntar ao usuário.",
      "inputSchema": {
        "type": "object",
        "properties": {},
        "required": []
      }
    },
    {
      "name": "request_login_otp",
      "description": "Dispara um código de acesso (OTP) por WhatsApp ou e-mail para o usuário entrar. Passo 1 do login.",
      "inputSchema": {
        "type": "object",
        "properties": {
          "identifier": {
            "type": "string",
            "description": "Telefone em E.164 (WhatsApp) ou e-mail"
          },
          "channel": {
            "type": "string",
            "enum": [
              "whatsapp",
              "email"
            ],
            "description": "whatsapp ou email"
          }
        },
        "required": [
          "identifier",
          "channel"
        ],
        "additionalProperties": false
      }
    },
    {
      "name": "verify_login_otp",
      "description": "Troca o código recebido por uma sessão. Devolve access_token e refresh_token para o agente agir em nome do usuário. Passo 2 do login.",
      "inputSchema": {
        "type": "object",
        "properties": {
          "identifier": {
            "type": "string",
            "description": "O mesmo identificador do passo 1"
          },
          "channel": {
            "type": "string",
            "enum": [
              "whatsapp",
              "email"
            ],
            "description": "whatsapp ou email"
          },
          "code": {
            "type": "string",
            "description": "Código de 6 dígitos recebido"
          }
        },
        "required": [
          "identifier",
          "channel",
          "code"
        ],
        "additionalProperties": false
      }
    },
    {
      "name": "whoami",
      "description": "Diz se há usuário autenticado no token atual e devolve id/e-mail/telefone. Não exige argumentos.",
      "inputSchema": {
        "type": "object",
        "properties": {},
        "required": [],
        "additionalProperties": false
      }
    },
    {
      "name": "create_booking",
      "description": "Cria uma reserva pendente para o usuário logado e segura a vaga. Use os ids vindos de get_parking_types. Confirme os dados com o usuário antes de reservar.",
      "inputSchema": {
        "type": "object",
        "properties": {
          "location_parking_type_id": {
            "type": "string",
            "description": "id do tipo de vaga (location_parking_type)"
          },
          "check_in_at": {
            "type": "string",
            "format": "date-time",
            "description": "Check-in ISO-8601"
          },
          "check_out_at": {
            "type": "string",
            "format": "date-time",
            "description": "Check-out ISO-8601"
          },
          "fare_tier": {
            "type": "string",
            "enum": [
              "basica",
              "flex",
              "superflex"
            ],
            "description": "Tarifa (default basica)"
          },
          "add_on_service_ids": {
            "type": "array",
            "items": {
              "type": "string"
            },
            "description": "Serviços adicionais (opcional)"
          },
          "coupon_code": {
            "type": "string",
            "description": "Cupom (opcional)"
          },
          "passenger_count": {
            "type": "integer",
            "description": "Nº de passageiros (opcional)"
          },
          "has_pcd": {
            "type": "boolean",
            "description": "Vaga PCD (opcional)"
          }
        },
        "required": [
          "location_parking_type_id",
          "check_in_at",
          "check_out_at"
        ],
        "additionalProperties": false
      }
    },
    {
      "name": "set_booking_customer",
      "description": "Preenche os dados do pagador na reserva (CPF/CNPJ e telefone são exigidos no pagamento). Campos ausentes ficam como estão.",
      "inputSchema": {
        "type": "object",
        "properties": {
          "booking_code": {
            "type": "string",
            "description": "Código da reserva (MP-...)"
          },
          "tax_id": {
            "type": "string",
            "description": "CPF ou CNPJ do pagador"
          },
          "phone": {
            "type": "string",
            "description": "Telefone com DDD (E.164)"
          },
          "email": {
            "type": "string",
            "description": "E-mail do pagador"
          },
          "first_name": {
            "type": "string",
            "description": "Nome"
          },
          "last_name": {
            "type": "string",
            "description": "Sobrenome"
          }
        },
        "required": [
          "booking_code"
        ],
        "additionalProperties": false
      }
    },
    {
      "name": "add_vehicle",
      "description": "Cadastra um veículo do usuário pela placa. Devolve o vehicle_id para vincular à reserva.",
      "inputSchema": {
        "type": "object",
        "properties": {
          "license_plate": {
            "type": "string",
            "description": "Placa"
          },
          "model": {
            "type": "string",
            "description": "Modelo (opcional)"
          },
          "color": {
            "type": "string",
            "description": "Cor (opcional)"
          },
          "set_default": {
            "type": "boolean",
            "description": "Tornar o veículo padrão (opcional)"
          }
        },
        "required": [
          "license_plate"
        ],
        "additionalProperties": false
      }
    },
    {
      "name": "set_booking_vehicle",
      "description": "Vincula um veículo já cadastrado (vehicle_id) à reserva.",
      "inputSchema": {
        "type": "object",
        "properties": {
          "booking_code": {
            "type": "string",
            "description": "Código da reserva (MP-...)"
          },
          "vehicle_id": {
            "type": "string",
            "description": "id do veículo (de add_vehicle ou list)"
          }
        },
        "required": [
          "booking_code",
          "vehicle_id"
        ],
        "additionalProperties": false
      }
    },
    {
      "name": "list_my_bookings",
      "description": "Lista as reservas do usuário logado.",
      "inputSchema": {
        "type": "object",
        "properties": {
          "limit": {
            "type": "integer",
            "description": "máximo (default 10)"
          }
        },
        "required": [],
        "additionalProperties": false
      }
    },
    {
      "name": "get_booking",
      "description": "Detalhe de uma reserva do usuário pelo código.",
      "inputSchema": {
        "type": "object",
        "properties": {
          "booking_code": {
            "type": "string",
            "description": "Código (MP-...)"
          }
        },
        "required": [
          "booking_code"
        ],
        "additionalProperties": false
      }
    },
    {
      "name": "get_booking_status",
      "description": "Estado da reserva e do pagamento (para acompanhar a confirmação sem consultar tabelas). Devolve status, pagamento e expiração.",
      "inputSchema": {
        "type": "object",
        "properties": {
          "booking_code": {
            "type": "string",
            "description": "Código (MP-...)"
          }
        },
        "required": [
          "booking_code"
        ],
        "additionalProperties": false
      }
    },
    {
      "name": "cancel_booking",
      "description": "Cancela uma reserva do usuário. Confirme com o usuário antes de cancelar.",
      "inputSchema": {
        "type": "object",
        "properties": {
          "booking_code": {
            "type": "string",
            "description": "Código (MP-...)"
          },
          "reason": {
            "type": "string",
            "description": "Motivo (opcional)"
          }
        },
        "required": [
          "booking_code"
        ],
        "additionalProperties": false
      }
    }
  ]
}
