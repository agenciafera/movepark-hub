{
  "name": "movepark-hub",
  "private": true,
  "version": "0.1.0",
  "type": "module",
  "scripts": {
    "prepare": "lefthook install",
    "dev": "node --import ./scripts/ws-polyfill.mjs node_modules/.bin/vite",
    "build": "tsc -b && node --import ./scripts/ws-polyfill.mjs node_modules/.bin/vite-react-ssg build",
    "preview": "bun run build && wrangler dev",
    "lint": "eslint .",
    "typecheck": "tsc -b --noEmit",
    "test": "./scripts/vitest-run.sh --project unit",
    "test:unit": "./scripts/vitest-run.sh --project unit",
    "test:watch": "vitest --project unit",
    "test:int": "./scripts/vitest-run.sh --project integration",
    "test:db": "supabase test db",
    "test:edge": "deno test --no-check --allow-env --allow-net supabase/functions",
    "coverage": "./scripts/vitest-run.sh --project unit --coverage",
    "gen:types": "supabase gen types typescript --linked > src/types/database.ts",
    "deploy": "bun run build && wrangler deploy",
    "deploy:api": "wrangler deploy -c wrangler.api.jsonc",
    "gen:cards": "node scripts/gen-card-hashes.mjs",
    "lint:openapi": "node scripts/check-openapi-drift.mjs"
  },
  "dependencies": {
    "@hookform/resolvers": "^3.10.0",
    "@radix-ui/react-accordion": "^1.2.14",
    "@radix-ui/react-avatar": "^1.2.0",
    "@radix-ui/react-checkbox": "^1.3.5",
    "@radix-ui/react-dialog": "^1.1.17",
    "@radix-ui/react-dropdown-menu": "^2.1.18",
    "@radix-ui/react-label": "^2.1.10",
    "@radix-ui/react-popover": "^1.1.17",
    "@radix-ui/react-scroll-area": "^1.2.12",
    "@radix-ui/react-select": "^2.3.1",
    "@radix-ui/react-separator": "^1.1.10",
    "@radix-ui/react-slot": "^1.3.0",
    "@radix-ui/react-tabs": "^1.1.15",
    "@radix-ui/react-toast": "^1.2.17",
    "@radix-ui/react-tooltip": "^1.2.10",
    "@supabase/supabase-js": "^2.108.2",
    "@tanstack/react-query": "^5.101.1",
    "@tanstack/react-table": "^8.21.3",
    "@types/qrcode": "^1.5.6",
    "class-variance-authority": "^0.7.1",
    "clsx": "^2.1.1",
    "cmdk": "^1.1.1",
    "date-fns": "^3.6.0",
    "date-fns-tz": "^3.2.0",
    "embla-carousel-autoplay": "^8.6.0",
    "embla-carousel-react": "^8.6.0",
    "gsap": "^3.15.0",
    "lucide-react": "^0.408.0",
    "qrcode": "^1.5.4",
    "react": "^18.3.1",
    "react-day-picker": "^8.10.2",
    "react-dom": "^18.3.1",
    "react-helmet-async": "^1.3.0",
    "react-hook-form": "^7.80.0",
    "react-phone-number-input": "^3.4.17",
    "react-router-dom": "^6.30.4",
    "recharts": "^2.15.4",
    "sonner": "^1.7.4",
    "tailwind-merge": "^2.6.1",
    "tailwindcss-animate": "^1.0.7",
    "vite-plugin-sitemap": "^0.8.2",
    "vite-react-ssg": "^0.9.1-beta.1",
    "ws": "^8.21.0",
    "zod": "^3.25.76"
  },
  "devDependencies": {
    "@secretlint/secretlint-rule-preset-recommend": "^13.0.2",
    "@testing-library/jest-dom": "^6.9.1",
    "@testing-library/react": "^16.3.2",
    "@testing-library/user-event": "^14.6.1",
    "@types/node": "^22.20.0",
    "@types/react": "^18.3.31",
    "@types/react-dom": "^18.3.7",
    "@types/ws": "^8.18.1",
    "@typescript-eslint/eslint-plugin": "^8.62.0",
    "@typescript-eslint/parser": "^8.62.0",
    "@vitejs/plugin-react-swc": "^3.11.0",
    "@vitest/coverage-v8": "^3.2.6",
    "autoprefixer": "^10.5.2",
    "eslint": "^9.39.4",
    "eslint-plugin-react-hooks": "^5.2.0",
    "eslint-plugin-react-refresh": "^0.4.26",
    "globals": "^17.7.0",
    "happy-dom": "^20.10.6",
    "lefthook": "^2.1.9",
    "msw": "^2.14.6",
    "postcss": "^8.5.15",
    "prettier": "^3.8.5",
    "prettier-plugin-tailwindcss": "^0.6.14",
    "secretlint": "^13.0.2",
    "tailwindcss": "^3.4.19",
    "typescript": "^6.0.3",
    "vite": "^6.4.3",
    "vitest": "^3.2.6",
    "wrangler": "^4.105.0"
  }
}
