{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "hooks": {
    "PreToolUse": [
      {
        "matcher": "Write|Edit|MultiEdit",
        "hooks": [
          {
            "type": "command",
            "command": "bash \"$CLAUDE_PROJECT_DIR/.claude/hooks/revisar-texto-gate.sh\"",
            "timeout": 15,
            "statusMessage": "Portão de revisão de texto"
          }
        ]
      }
    ]
  }
}
