# Envs da suíte E2E (Playwright). Copie para .env.e2e e preencha.
# O .env.e2e NÃO vai para o git: contém a service_role key.
#
# VITE_SUPABASE_URL e VITE_SUPABASE_ANON_KEY já vêm do .env versionado.
# Só o que está abaixo precisa ser preenchido.

# service_role do projeto Supabase (Project Settings > API > service_role).
# Hoje a suíte roda contra o banco de PRODUÇÃO com a fixture Mercy.
SUPABASE_SERVICE_ROLE_KEY=

# Usuários de teste que já existem no banco. Descomente para sobrescrever.
# E2E_MANAGER_EMAIL=developer@fera.ag
# E2E_OPERATOR_EMAIL=peu+mercy@fera.ag

# Onde o app responde. Default: dev server local que o Playwright sobe sozinho.
# Aponte para um preview do Cloudflare se quiser validar o build publicado.
# E2E_BASE_URL=http://localhost:5273
