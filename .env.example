# Variáveis de ambiente do front (Vite). Copie para `.env.local` e preencha.
# A anon key do Supabase é pública por design (RLS protege). NÃO coloque secrets de service_role aqui.

VITE_SUPABASE_URL=
VITE_SUPABASE_ANON_KEY=

# Google Maps JavaScript API — usado pelo autocomplete de endereço do onboarding do parceiro
# (GooglePlacesAutocomplete). A key do Maps é pública por design; restrinja por HTTP referrer no
# Google Cloud Console. Sem essa var, o autocomplete degrada para endereço + lat/lng manuais.
VITE_GOOGLE_MAPS_API_KEY=

# Domínio canônico do Hub (SEO/links). Default: https://hub.movepark.co
VITE_PUBLIC_SITE_URL=
